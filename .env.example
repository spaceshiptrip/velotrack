# ── Garmin Connect ──────────────────────────────────────────────────────────
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your_garmin_password
# Set True if using Garmin CN (mainland China)
GARMIN_IS_CN=False
# How often to sync (minutes)
GARMIN_SYNC_INTERVAL=30
# Days of history to backfill on first run
GARMIN_INITIAL_BACKFILL_DAYS=90

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change_this_in_production
# Full DSN (override for external DB)
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
# JWT expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── BRouter ──────────────────────────────────────────────────────────────────
# Option A: bundled Docker container (start with: bash setup.sh --with-brouter)
BROUTER_ENDPOINT=http://brouter:17777
# Option B: public BRouter server (rate-limited, no setup needed)
# BROUTER_ENDPOINT=https://brouter.de/brouter
# Option C: leave empty to disable route planning
# BROUTER_ENDPOINT=

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
# For GitHub Pages deployment: set to your backend URL or leave empty for GPX-only mode
# VITE_API_URL=https://api.yourserver.com

# ── Features ──────────────────────────────────────────────────────────────────
# Comma separated: activities,health,sleep,hrv,body_battery,stress,steps
GARMIN_FETCH_SELECTION=activities,health,sleep,hrv,body_battery,stress,steps,training_readiness

# ── Tiles / Maps ─────────────────────────────────────────────────────────────
# Default: OpenStreetMap. Can use any XYZ tile URL.
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_TILE_URL=https://api.mapbox.com/styles/v1/mapbox/outdoors-v12/tiles/{z}/{x}/{y}?access_token=YOUR_TOKEN
VITE_MAPBOX_TOKEN=
